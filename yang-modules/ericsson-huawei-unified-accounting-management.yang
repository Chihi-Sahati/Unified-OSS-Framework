    type enumeration {
      enum DRAFT {
        value 1;
        description "Budget in draft state";
      }
      enum SUBMITTED {
        value 2;
        description "Budget submitted for approval";
      }
      enum APPROVED {
        value 3;
        description "Budget approved";
      }
      enum ACTIVE {
        value 4;
        description "Budget currently active";
      }
      enum SUSPENDED {
        value 5;
        description "Budget temporarily suspended";
      }
      enum EXHAUSTED {
        value 6;
        description "Budget fully consumed";
      }
      enum EXPIRED {
        value 7;
        description "Budget period expired";
      }
      enum CLOSED {
        value 8;
