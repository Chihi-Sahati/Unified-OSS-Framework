  typedef usage-record-type {
    description 
      "Usage record classification for data collection.";
    type enumeration {
      enum RAW {
        value 1;
        description "Raw usage measurement";
      }
      enum AGGREGATED {
        value 2;
        description "Aggregated usage summary";
      }
      enum BILLED {
        value 3;
        description "Billed usage record";
      }
      enum ESTIMATED {
        value 4;
        description "Estimated usage";
      }
      enum CORRECTED {
        value 5;
        description "Corrected usage record";
      }
      enum ADJUSTED {
        value 6;
        description "Adjusted usage record";
      }
    }
  }

  /***************************************************************************
   * TYPEDEF DEFINITIONS - Identifiers
   ***************************************************************************/
  
  typedef accounting-id-type {
    description 
      "Unique identifier for accounting records.
       UUID v4 format for global uniqueness.";
    type string {
      length "36..36";
      pattern "[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-4[0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}";
    }
  }
  
  typedef invoice-number-type {
    description 
      "Human-readable invoice number format.";
    type string {
      length "1..32";
      pattern "INV-[0-9]{4}-[0-9]{6}";
    }
  }
  
  typedef cost-center-id-type {
    description 
      "Cost center identifier format.";
    type string {
      length "1..64";
      pattern "CC-[A-Z0-9]{2,4}-[0-9]{4,8}";
    }
  }
  
  typedef license-id-type {
    description 
      "License identifier format for tracking.";
    type string {
      length "1..128";
      pattern "[A-Za-z0-9_\\-\\.:]+";
    }
  }
  
  typedef rate-card-id-type {
    description 
      "Rate card identifier format.";
    type string {
      length "1..64";
      pattern "RC-[A-Z]{2,4}-[0-9]{4,8}";
    }
  }

  /***************************************************************************
   * TYPEDEF DEFINITIONS - Financial Types
   ***************************************************************************/
  
  typedef monetary-amount {
    description 
      "Monetary amount with high precision for financial calculations.
       Supports values up to billions with cent precision.";
    type decimal64 {
      fraction-digits 4;
      range "-999999999999.9999..999999999999.9999";
    }
  }
  
  typedef positive-monetary-amount {
    description 
      "Positive monetary amount for charges and costs.";
    type decimal64 {
      fraction-digits 4;
      range "0.0000..999999999999.9999";
    }
  }
  
  typedef percentage-value {
    description 
      "Percentage value for rates, discounts, and allocations.
       Supports values from 0 to 100 with two decimal precision.";
    type decimal64 {
      fraction-digits 2;
      range "0.00..100.00";
    }
  }
  
  typedef discount-percentage {
    description 
      "Discount percentage for billing adjustments.";
    type decimal64 {
      fraction-digits 2;
      range "0.00..100.00";
    }
  }
  
  typedef tax-rate {
    description 
      "Tax rate percentage for invoice calculations.";
    type decimal64 {
      fraction-digits 3;
      range "0.000..100.000";
    }
  }

  /***************************************************************************
   * TYPEDEF DEFINITIONS - Time and Duration
   ***************************************************************************/
  
  typedef duration-seconds {
    description "Duration in seconds";
    type uint32 {
      range "0..4294967295";
    }
  }
  
  typedef duration-minutes {
    description "Duration in minutes";
    type uint32 {
      range "0..525600";
    }
  }
  
  typedef duration-hours {
    description "Duration in hours";
    type uint16 {
      range "0..8760";
    }
  }
  
  typedef duration-days {
    description "Duration in days";
    type uint16 {
      range "0..365";
    }
  }

  /***************************************************************************
   * TYPEDEF DEFINITIONS - Vendor Specifics
   ***************************************************************************/
  
  typedef vendor-accounting-type {
    description "Vendor system enumeration for accounting sources";
    type enumeration {
      enum ERICSSON {
        value 1;
        description "Ericsson ENM system";
      }
      enum HUAWEI {
        value 2;
        description "Huawei U2000/iManager system";
      }
      enum NOKIA {
        value 3;
