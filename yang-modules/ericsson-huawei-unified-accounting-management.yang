      }
      enum TRIAL {
        value 10;
        description "Trial/evaluation license";
      }
      enum OPEN_SOURCE {
        value 11;
        description "Open source license";
      }
      enum VOLUME_LICENSE {
        value 12;
        description "Volume licensing agreement";
      }
      enum SITE_LICENSE {
        value 13;
        description "Site-wide license";
      }
      enum ENTERPRISE_LICENSE {
        value 14;
        description "Enterprise-wide license";
      }
