    type enumeration {
      enum PERPETUAL {
        value 1;
        description "Perpetual license, one-time purchase";
      }
      enum SUBSCRIPTION_MONTHLY {
        value 2;
        description "Monthly subscription license";
      }
      enum SUBSCRIPTION_ANNUAL {
        value 3;
        description "Annual subscription license";
      }
      enum USAGE_BASED {
        value 4;
        description "Pay-per-use licensing model";
      }
      enum PER_NODE {
        value 5;
        description "Per-node licensing";
      }
      enum PER_USER {
        value 6;
        description "Per-user licensing";
      }
      enum PER_CORE {
        value 7;
        description "Per-CPU-core licensing";
      }
      enum PER_SOCKET {
        value 8;
        description "Per-socket licensing";
      }
      enum PER_INSTANCE {
        value 9;
