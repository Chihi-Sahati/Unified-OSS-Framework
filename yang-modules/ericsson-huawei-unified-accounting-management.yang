      }
      enum ZTE {
        value 4;
        description "ZTE NetNumen system";
      }
      enum SAMSUNG {
        value 5;
        description "Samsung NetManager system";
      }
      enum CISCO {
        value 6;
        description "Cisco Prime/NSO system";
      }
      enum CALCULATED {
        value 99;
        description "Calculated or derived data";
      }
    }
  }
  
  typedef data-collection-method {
    description 
