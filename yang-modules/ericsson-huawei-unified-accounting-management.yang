      }
      enum FILE_UPLOAD {
        value 3;
        description "File-based data upload (CSV, XML)";
      }
      enum API_QUERY {
        value 4;
        description "REST/GraphQL API query";
      }
      enum LOG_PARSING {
        value 5;
        description "Log file parsing";
      }
      enum KAFKA_STREAM {
        value 6;
        description "Kafka message streaming";
      }
      enum SYSLOG {
        value 7;
        description "Syslog message collection";
      }
      enum DATABASE_REPLICATION {
        value 8;
        description "Database replication/sync";
      }
    }
  }

